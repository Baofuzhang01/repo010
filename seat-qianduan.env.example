# Fill these before using bootstrap_new_server.sh.
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=
FLASK_SECRET_KEY=

# Optional runtime settings.
SERVER_PROJECT_ROOT=/opt/Main_ChaoXingReserveSeat
SEAT_STORE_DB_PATH=/opt/Main_ChaoXingReserveSeat/server_store/seat_store.sqlite3
SERVER_DISPATCH_HOST=127.0.0.1
SERVER_DISPATCH_PORT=8788
SERVER_DISPATCH_API_KEY=

# Result center is intentionally disabled by default.
# Only enable this on the designated central result server.
ENABLE_RESERVE_RESULT_CENTER=0
RESERVE_RESULT_REPORT_TOKEN=
RESERVE_RESULT_CENTER_URL=http://your-center-server
RESERVE_RESULT_SERVER_ID=
RESERVE_RESULT_REPORT_TIMEOUT=8
ENABLE_RESERVE_RESULT_REPORT_TIMER=1
# Optional: force local SQLite write instead of HTTP upload.
# The central server automatically uses local write when ENABLE_RESERVE_RESULT_CENTER=1.
RESERVE_RESULT_LOCAL_WRITE=0

# Server-side worker2 watchdog. This mirrors worker2.js as a systemd timer.
SERVER_WORKER2_ENABLED=1
SERVER_WORKER2_TRIGGER_API=https://tongyi.baofuzhang0402.workers.dev/api
SERVER_WORKER2_API_KEY=
SERVER_WORKER2_UI_KEY=
SERVER_WORKER2_HEARTBEAT_SOURCE_ACCOUNT_ID=
SERVER_WORKER2_HEARTBEAT_SOURCE_NAMESPACE_ID=
SERVER_WORKER2_HEARTBEAT_SOURCE_API_TOKEN=
SERVER_WORKER2_FEISHU_WEBHOOK=
SERVER_WORKER2_FEISHU_KEYWORD=检测
SERVER_WORKER2_RECORDS_DIR=/opt/Main_ChaoXingReserveSeat/server_worker2_watchdog/records
SERVER_WORKER2_SCHEDULE_FILE=/opt/Main_ChaoXingReserveSeat/server_worker2_watchdog/schedule.json
SERVER_WORKER2_ALLOW_TIMER_EDIT=1
SERVER_WORKER2_TIMER_UNIT_PATH=/etc/systemd/system/seat-worker2-watchdog.timer
SERVER_WORKER2_TIMER_NAME=seat-worker2-watchdog.timer
SERVER_WORKER2_SERVICE_NAME=seat-worker2-watchdog.service
SERVER_WORKER2_UI_HOST=127.0.0.1
SERVER_WORKER2_UI_PORT=8790

# Reservation-side optional settings can continue to be added below.
CHAOJIYING_USERNAME=20260521rq36tq82
CHAOJIYING_PASSWORD=
CHAOJIYING_SOFT_ID=96001
CHAOJIYING_CODETYPE=9800

# Legacy fallback/testing only; formal textclick OCR defaults to Chaojiying.
TULINGCLOUD_USERNAME=baofuzhang
TULINGCLOUD_PASSWORD=
TULINGCLOUD_MODEL_ID=35484990
